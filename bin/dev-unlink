#!/bin/bash
set -euo pipefail

ZSHRC="${ZDOTDIR:-$HOME}/.zshrc"

if [[ ! -f $ZSHRC ]]; then
  echo "No ~/.zshrc found at $ZSHRC."
  exit 0
fi

if ! grep -qE '^# >>> omarchy-zsh dev' "$ZSHRC"; then
  echo "No dev block found in $ZSHRC."
  exit 0
fi

awk '
  /^# >>> omarchy-zsh dev/ { skip=1; next }
  skip && /^# <<< omarchy-zsh dev/ { skip=0; next }
  !skip { print }
' "$ZSHRC" > "$ZSHRC.tmp"
mv "$ZSHRC.tmp" "$ZSHRC"

echo "Removed dev block from $ZSHRC"
echo "Open a new zsh shell to fall back to the packaged version."
